{% extends 'base.html' %}
{% load static %}
{% load get_item %}
{% load react_tags %}
{% block subtitle %}
    {% if current_table == "bodypart" %}
        Body Part
    {% else %}
        {{ current_table|capfirst }}
    {% endif %}
    Selection {% endblock %}
{% block content %}
<div id="main-content">
<script>
document.addEventListener('DOMContentLoaded', function () {
    var selectAll = document.getElementById('selectAll');
    var singles = document.querySelectorAll('.checkSingle');
    var submitBtns = document.querySelectorAll('input[name="commit"][value="Submit checked options"]');

    function updateSubmitButton() {
        var hasSelection =
            document.querySelectorAll('input[type="hidden"][name="id"]').length > 0 ||
            document.querySelectorAll('.checkSingle:checked').length > 0;
        submitBtns.forEach(function (btn) { btn.disabled = !hasSelection; });
    }

    if (selectAll) {
        selectAll.addEventListener('change', function () {
            singles.forEach(function (cb) { cb.checked = selectAll.checked; });
            updateSubmitButton();
        });
    }

    singles.forEach(function (cb) {
        cb.addEventListener('change', function () {
            if (selectAll) {
                selectAll.checked = document.querySelectorAll('.checkSingle').length ===
                                    document.querySelectorAll('.checkSingle:checked').length;
            }
            updateSubmitButton();
        });
    });

    updateSubmitButton();

    var form = document.querySelector('#query-wizard-filter-table-options form');
    if (form) {
        new MutationObserver(updateSubmitButton).observe(form, { childList: true, subtree: true });
    }
});
</script>
{% if current_table == 'variable' and not request.session.table_var_select_done.bodypart %}
        <p style="font-size: 16px;">No bodyparts were specified. Please select bodyparts before attempting to select variables. </p>
        <div style="margin-bottom: 30px;">
            <form action="{% url 'initialize_query' request.session.scalar_or_3d %}" method="post" />
            {% csrf_token %}
            <input type="hidden" value="{{ current_table }}" name="table" />
            <input class="submit" type="submit" value="Return to Query Wizard" name="commit" />
        </form>
        </div>
{% else %}
<div id="table-scroll">
<div id="query-wizard-filter-table-options">


    <form action="{% url 'initialize_query' request.session.scalar_or_3d %}" method="post" />
    {% csrf_token %}
    <div class="submit-buttons">
        <input type="hidden" value="{{ current_table }}" name="table" />
        <input class="submit" type="submit" value="Cancel" name="commit" />
        <input class="submit" type="submit" value="Submit checked options" name="commit" />
    </div>
    <table class="selection-table">
    <thead>
    {% if current_table == 'variable' %}
    <tr>
        <th>Bodypart</th>
        <th>Variable ID</th>
        <th>Variable name</th>
        <th>Variable label</th>
        <th><input id="selectAll" type="checkbox"></th>
    </tr>
    </thead>
    <tbody>
        {% for value in values %}
        <tr>
            <td>{{ value.bodypart_name }}</td>
            <td>{{ value.var_id}}</td>
            <td>{{ value.var_name }}</td>
            <td>{{ value.var_label }}</td>
            <td class="centered"><input type="checkbox" class="checkSingle" name='id' value="{{ value.var_id }}"
                    {% if value.var_id in selected_ids %} CHECKED {% endif %}></td>
        </tr>
        {% endfor %}
    {% elif current_table == 'bodypart' or current_table == 'taxon' %}
    </thead>
    <tbody>
        <tr><td>
        <script>
            window.PRIMO_TREE_DATA = {{ tree_data_json|safe }};
            window.PRIMO_INITIAL_SELECTION = {{ tree_selection_json|safe }};
        </script>
        <link rel="stylesheet" href="{% react_asset 'main.css' %}">
        <div id="react-tree-root"></div>
        <script defer src="{% react_asset 'main.js' %}"></script>
        </td></tr>
    {% else %} {# sex or fossil #}
    <tr>
        <th width="80%">{{ current_table|capfirst }}</th>
        <th><label><input id="selectAll" type="checkbox"> Select all</label></th>
    </tr>
    </thead>
    <tbody>
        {% for value in values %}
        <tr>
            <td>{{ value.label }}</td>
            <td class="centered"><input type="checkbox" class="checkSingle" name='id' value="{{ value.id }}"
                {% if value.id in selected_ids %} CHECKED {% endif %}></td>
        </tr>
        {% endfor %}
    {% endif %}
    </tbody>
    </table>
    <div class="submit-buttons">
        <input type="hidden" value="{{ current_table }}" name="table"  />
        <input class="submit" type="submit" value="Cancel" name="commit"/>
        <input class="submit" type="submit" value="Submit checked options" name="commit"/>
    </div>
    </form>
</div>
</div>
    {% endif %}

{% endblock %}
